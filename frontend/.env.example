# All optional — every one of these falls back to the local-dev value
# (see src/config/apiUrls.js) if unset, so local development needs no .env
# file at all. Set these for any non-local deploy.

VITE_API_URL=http://localhost:5000/api
VITE_INVOICE_API_URL=http://localhost:5001/api
VITE_INVOICE_V2_API_URL=http://localhost:5002/api
VITE_SOCKET_URL=http://localhost:5000
