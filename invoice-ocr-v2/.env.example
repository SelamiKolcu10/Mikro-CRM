# Invoice OCR v2 — Environment Variables
# Yerli OCR Servisi (Tesseract.js) — Dış API Bağımlılığı SIFIR
# Copy this to .env and fill in your values

# MongoDB Connection (can share with CRM or use separate DB)
MONGO_URI=mongodb://your_connection_string_here

# Server Port (default: 5002 — separate from v1 on 5001 and CRM on 5000)
PORT=5002

# Environment
NODE_ENV=development

# OCR Language (Tesseract language code — 'tur' for Turkish)
OCR_LANGUAGE=tur

# Upload Config
MAX_FILE_SIZE_MB=10
MAX_BULK_FILES=20

# VAT Validation Tolerance (in TL)
VAT_TOLERANCE=0.50

# Must be IDENTICAL to backend/.env and invoice-ocr-service/.env — shared auth trust
JWT_SECRET=your_super_secret_jwt_key_here

# Frontend origin for CORS
FRONTEND_URL=http://localhost:5173
