# Invoice OCR Service — Environment Variables
# Copy this to .env and fill in your values

# MongoDB Connection (can share with CRM or use separate DB)
MONGO_URI=mongodb://your_connection_string_here

# Google Gemini AI API Key (get from https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Server Port (default: 5001 — separate from CRM backend on 5000)
PORT=5001

# Environment
NODE_ENV=development

# Upload Config
MAX_FILE_SIZE_MB=10
MAX_BULK_FILES=20

# VAT Validation Tolerance (in TL)
VAT_TOLERANCE=0.50
